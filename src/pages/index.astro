---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Home";
---

<BaseLayout pageTitle={pageTitle}  showBookButton={false}>
  <!-- hero image -->
   <!-- insert H1 that is hidden or make the logo h1 -->
  <img src="https://source.unsplash.com/random/1200x900" alt="Hero Image" />
  <!-- end of hero image -->
  <!-- Insert scroll for more -->
  <h2>
    Unbelievably Meditative Adventure (UMA) Campground offers a quaint, inviting
    space to escape from the everyday monotony of life...
  </h2>
  <!-- form -->
  <form action="">
    <div>
      <label for="check-in-date">Check-in Date:</label>
      <input type="date" id="check-in-date" name="check-in-date" required />
    </div>
    <div>
      <label for="check-out-date">Check-out Date:</label>
      <input type="date" id="check-out-date" name="check-out-date" required />
</div>
    <label for="campers-size">Campers:</label>
    <input
      type="number"
      id="campers-size"
      name="campers-size"
      min="1"
      max="6"
      required
    />
    <label for="camp-type">Camp Type</label>
    <select id="camp-type" name="camp-type" required>
      <option value="1" selected>Basic Site</option>
      <option value="2">Powered Site</option>
      <option value="3">Group Site</option>
    </select>
    <button type="submit" class="search-available-sites">Search Available Sites</button>
  </form>
  <div id="campsite-results">
  </div>

  <div>
    <div>
      <img
        src="https://source.unsplash.com/random/1200x900"
        alt="serving-image"
      />
      <p>Been serving families since <b>2023</b></p>
    </div>
    <div>
      <img
        src="https://source.unsplash.com/random/1200x900"
        alt="camping-image"
      />
      <p><b>15</b>Campsites</p>
    </div>
    <div>
      <img
        src="https://source.unsplash.com/random/1200x900"
        alt="nature-image"
      />
      <p><b>4.9</b> Google</p>
    </div>
  </div>
  <div class="interactive-dashboard">
    <button>Amenities</button>
    <button>Things to Do</button>
    <button>Nearby Landmarks</button>
    <button>Sites & Rates</button>
  </div>
  <div>
    <div class="star-rating">
      <span class="star checked">&#9733;</span>
      <span class="star checked">&#9733;</span>
      <span class="star checked">&#9733;</span>
      <span class="star">&#9733;</span>
      <span class="star">&#9733;</span>
    </div>
    <p>Fabio Smith</p>
    <p>Miner</p>
    <p>
      The place has lots of hiking trails! I enjoyed my stay in UMA. I was
      skeptical at first but the campground is full of life, from trees, bushes
      and birds. I would definitely come back again.
    </p>
  </div>
  <!-- add the carousel form using javascript -->
<form>
  <h2>Got Any Questions?</h2>
  <label for="email">Email Address</label>
  <input type="email" id="email" name="email" placeholder="Your email" required />
  <label for="question">Message:</label>
  <textarea id="question" name="question" rows="4" required></textarea>
  <button type="submit">Message Us</button>
  <small>Or you can head straight to our <a href="/faq">FAQ's page</a></small>
</form>
<script type="module">
import { supabase } from '/src/db/supabase';
    console.log("SUPABASE:", supabase);


  const searchButton = document.querySelector(".search-available-sites");
  const campsiteResultsContainer = document.getElementById("campsite-results");
 const checkInInput = document.getElementById("check-in-date");
 const checkOutInput = document.getElementById("check-out-date");
 const camperSizeInput = document.getElementById("campers-size");
 const campTypeSelect = document.getElementById("camp-type");

  searchButton?.addEventListener("click", async (e) =>{
    e.preventDefault();

    console.log("clicked")
     if (campsiteResultsContainer) {
      campsiteResultsContainer.innerHTML = '<p>Searching available spots...</p>';
    }
    const checkInDate = checkInInput?.value;
    const checkOutDate = checkOutInput?.value;
    const camperSize = Number(camperSizeInput?.value);
    const campType = Number(campTypeSelect?.value);
    
    if (!checkInDate || !checkOutDate) {
      alert('Please select both a check-in and check-out date.');
      return;
    }

   const { data: availableCampsites, error: bookingError } = await supabase.rpc( "get_available_campsites",
  {
    p_check_in: checkInDate,
    p_check_out: checkOutDate,
    p_campers: camperSize,
    p_camp_type: campType
  });

 if (bookingError) {
  console.error(bookingError);
  if (campsiteResultsContainer) {
    campsiteResultsContainer.innerHTML = '<p>There is an error.</p>';
  }
  return;
}


  if (campsiteResultsContainer) {
    if (!availableCampsites || availableCampsites.length === 0) {
      campsiteResultsContainer.innerHTML = '<p>No campsites available matching your criteria.</p>';
      return;
    }

    console.log(availableCampsites);
    campsiteResultsContainer.innerHTML = availableCampsites
      .map(site => `
        <div class="site-card">
          <h3>${site.name}</h3>
          <img src="${site.image}" alt="${site.name} campsite image">
          <p>Type: ${site.type_name} | Max Guests: ${site.max_campers}</p>
          <p class="price">$${site.price} / night</p>
        </div>
      `).join('');
  }
  })
</script>
</BaseLayout>

